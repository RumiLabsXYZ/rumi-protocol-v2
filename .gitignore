pocket-ic

# analysis/demo directories
technical-analysis/
# Top-level xrc_demo/ is the legacy build workspace (gitignored). The
# tracked mock canister lives at src/xrc_demo/ so the integration tests
# can `include_bytes!` the wasm without depending on a developer's local
# build setup. To rebuild the mock wasm:
#   cargo build --target wasm32-unknown-unknown --release -p xrc-mock-canister
#   cp target/wasm32-unknown-unknown/release/xrc_mock_canister.wasm src/xrc_demo/xrc/xrc.wasm
/xrc_demo/
.playwright-mcp/

# Security: audit reports stay local (repo is PUBLIC)
audit-reports/

# Local design/spec/planning notes (whitepaper and existing tracked docs in this folder
# stay tracked; this only blocks new untracked additions from being committed)
docs/

# Superpowers local brainstorm/cache
.superpowers/

# Git worktrees (isolated workspaces for parallel feature work)
.worktrees/

# Loose screenshots at repo root (Claude Preview / browser captures during debugging).
# Tracked screenshots under docs/screenshots/ are unaffected because they're already
# in git history.
/explorer-*.png
/pr*-*.png
