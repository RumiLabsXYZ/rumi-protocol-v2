# --- Required ---
# The rumi_protocol_backend canister to monitor (staging kvg63-wiaaa-aaaao-bbabq-cai
# for the gated soft-launch; mainnet tfesu-vyaaa-aaaap-qrd7a-cai).
CANISTER_ID=kvg63-wiaaa-aaaao-bbabq-cai
# Path to the price-pusher identity PEM (secp256k1, e.g. `dfx identity export pusher > pusher.pem`).
# This must be a DEDICATED identity registered via set_price_pusher_principal — NEVER the developer key.
IDENTITY_PEM=./pusher.pem

# --- Network (defaults shown) ---
IC_NETWORK=ic                       # "ic" | "local"
# IC_HOST=https://icp-api.io        # derived from IC_NETWORK if unset (local -> http://127.0.0.1:4943)

# --- Monitor target (defaults: CFX on Conflux eSpace mainnet) ---
CHAIN_ID=1030                       # 1030 mainnet, 71 testnet
SYMBOL=CFX
COINGECKO_ID=conflux-token

# --- Thresholds (runbook defaults shown) ---
DRIFT_BPS=200                       # refresh when |market - on-chain| > 2%
MAX_AGE_SEC=300                     # refresh when the on-chain price is older than 5 min
CR_WARN_BAND_E4=16000               # alert when a vault's true CR < 1.6x
MCR_E4=13000                        # under-MCR alerts escalate to critical
OUTLIER_PCT=5                       # drop a source > 5% from the median
MIN_SOURCES=2                       # need >= 2 healthy sources to trust a median
POLL_SEC=60                         # poll loop cadence
DOWNTIME_INTERVALS=3                # self-downtime alert after 3 missed cycles
NATIVE_DECIMALS=18                  # CFX has 18 native decimals

# --- Alerting (optional) ---
# When set, alerts are also POSTed to this Slack incoming webhook. Always logged as JSON regardless.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
